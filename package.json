{
	"name": "nextjs-landing-template",
	"type": "module",
	"private": true,
	"scripts": {
		"build": "next build",
		"dev": "next dev --turbopack --port 4000",
		"eslint": "eslint",
		"eslint:fix": "eslint --fix",
		"generate:graphql": "graphql-codegen --config  src/integrations/codegen/codegen.ts",
		"lint": "npm run eslint && npm run prettier",
		"lint:fix": "npm run eslint:fix && npm run prettier:fix",
		"prebuild": "next telemetry --disable",
		"prettier": "prettier --check './src/**/*.{ts,tsx,css,scss}'",
		"prettier:fix": "prettier --write './src/**/*.{ts,tsx,css,scss}'",
		"start": "next start --port 4000"
	},
	"dependencies": {
		"@ark-ui/react": "^5.18.2",
		"@radix-ui/react-dialog": "^1.1.6",
		"@radix-ui/react-select": "^2.2.6",
		"@radix-ui/react-slot": "^1.1.2",
		"class-variance-authority": "^0.7.1",
		"client-only": "^0.0.1",
		"clsx": "^2.1.1",
		"dotenv": "^17.2.3",
		"embla-carousel": "^8.6.0",
		"embla-carousel-react": "^8.6.0",
		"lottie-react": "^2.4.1",
		"lucide-react": "^0.483.0",
		"next": "^15.4.5",
		"react": "^19.1.1",
		"react-dom": "^19.1.1",
		"server-only": "^0.0.1",
		"tailwind-merge": "^3.0.2",
		"valibot": "^1.2.0"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.3.1",
		"@eslint/js": "^9.32.0",
		"@ianvs/prettier-plugin-sort-imports": "^4.5.1",
		"@svgr/webpack": "^8.1.0",
		"@tsconfig/next": "^2.0.3",
		"@types/node": "^24.1.0",
		"@types/react": "^19.1.9",
		"@types/react-dom": "^19.1.7",
		"autoprefixer": "^10.4.22",
		"eslint": "^9.32.0",
		"eslint-config-flat-gitignore": "^2.1.0",
		"eslint-config-next": "^15.4.5",
		"eslint-plugin-unicorn": "^60.0.0",
		"globals": "^16.3.0",
		"postcss": "^8.5.6",
		"prettier": "^3.6.2",
		"prettier-plugin-pkg": "^0.21.2",
